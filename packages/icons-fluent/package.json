{
  "name": "@headless-adminapp/icons-fluent",
  "version": "1.5.1",
  "description": "Fluent UI icon adapters bridging Headless AdminApp icon abstractions to Fluent UI icons.",
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/headless-adminapp/adminapp.git",
    "directory": "packages/icons-fluent"
  },
  "bugs": {
    "url": "https://github.com/headless-adminapp/adminapp/issues"
  },
  "scripts": {
    "build:tsc": "tsc",
    "build:package": "ts-node ../../scripts/buildPackageJson.ts",
    "build": "pnpm run build:tsc && pnpm run build:package",
    "clean": "rm -rf dist && rm -f tsconfig.tsbuildinfo",
    "ts-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "test": "echo \"OK\""
  },
  "keywords": [
    "headless",
    "admin-panel",
    "icons",
    "fluent-ui",
    "react",
    "adapter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fluentui/react-icons": "^2.0.326",
    "@headless-adminapp/icons": "workspace:*"
  }
}
